# HyperMorphic SDRG — one-cell Google Colab Lean 4 checker
#
# Paste this entire script into ONE Google Colab Python cell and run it.
# It installs Lean 4 + Mathlib, creates a project, writes the complete
# HyperMorphicSDRG.lean formalization, and kernel-checks the file.

import base64
import os
import shutil
import subprocess
from pathlib import Path

PROJECT_NAME = "HyperMorphicSDRGLean"
LEAN_FILENAME = "HyperMorphicSDRG.lean"
WORK_ROOT = Path("/content")
PROJECT_DIR = WORK_ROOT / PROJECT_NAME
ELAN_BIN = Path.home() / ".elan" / "bin"

# The complete Lean source is embedded here, so no separate file upload is needed.
LEAN_SOURCE_BASE64 = """"""

def run(command: str, cwd: Path | None = None, env: dict | None = None) -> None:
    """Run a shell command and stop immediately if it fails."""
    print("\n" + "=" * 88)
    print("$", command)
    print("=" * 88)
    subprocess.run(
        command,
        shell=True,
        check=True,
        cwd=str(cwd) if cwd else None,
        env=env,
        executable="/bin/bash",
    )

print("=" * 88)
print("HYPERMORPHIC SDRG — LEAN 4 / MATHLIB FORMAL CHECK")
print("=" * 88)

# 1. Install small Linux prerequisites used by Elan, Git, and Mathlib cache files.
run("apt-get update -qq")
run(
    "DEBIAN_FRONTEND=noninteractive apt-get install -y -qq "
    "ca-certificates curl git zstd"
)

# 2. Install Elan, Lean's toolchain manager, if this Colab runtime does not have it.
if not (ELAN_BIN / "elan").exists():
    run(
        "curl -sSf https://elan.lean-lang.org/elan-init.sh "
        "| sh -s -- -y --default-toolchain none"
    )
else:
    print("\nElan is already installed; reusing it.")

# Ensure subprocesses can find elan, lake, and lean.
env = os.environ.copy()
env["PATH"] = f"{ELAN_BIN}:{env.get('PATH', '')}"

run("elan --version", env=env)

# 3. Recreate a clean Mathlib-backed project on every run.
if PROJECT_DIR.exists():
    print(f"\nRemoving previous project: {PROJECT_DIR}")
    shutil.rmtree(PROJECT_DIR)

run(
    f"lake +leanprover-community/mathlib4:lean-toolchain "
    f"new {PROJECT_NAME} math",
    cwd=WORK_ROOT,
    env=env,
)

# 4. Decode and write the exact Lean formalization.
lean_path = PROJECT_DIR / LEAN_FILENAME
lean_path.write_bytes(base64.b64decode(LEAN_SOURCE_BASE64))

print(f"\nWrote Lean source: {lean_path}")
print(f"Source size:       {lean_path.stat().st_size:,} bytes")

# 5. Resolve project dependencies and download Mathlib's precompiled artifacts.
# `lake update` is harmless for a fresh project and makes dependency state explicit.
run("lake update", cwd=PROJECT_DIR, env=env)
run("lake exe cache get", cwd=PROJECT_DIR, env=env)

# 6. Display the exact toolchain and formally check the source.
run("lean --version", cwd=PROJECT_DIR, env=env)
run("lake --version", cwd=PROJECT_DIR, env=env)
run(f"lake env lean {LEAN_FILENAME}", cwd=PROJECT_DIR, env=env)

print("\n" + "=" * 88)
print("✅ SUCCESS: Lean accepted HyperMorphicSDRG.lean with no kernel errors.")
print(f"Project: {PROJECT_DIR}")
print(f"File:    {lean_path}")
print("=" * 88)
